@prefix : <http://example.org/space#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================================
# Solar System Knowledge Graph — RDF Studio demo
# ============================================================

# ---- Ontology ----

<http://example.org/space#> a owl:Ontology ;
    rdfs:label "Solar System" ;
    rdfs:comment "A knowledge graph modelling the Sun, planets, moons, and spacecraft in our solar system." .

:CelestialBody a owl:Class ;
    rdfs:label "Celestial Body" ;
    rdfs:comment "Any natural body in space." .

:Star a owl:Class ;
    rdfs:subClassOf :CelestialBody ;
    rdfs:label "Star" .

:Planet a owl:Class ;
    rdfs:subClassOf :CelestialBody ;
    rdfs:label "Planet" .

:DwarfPlanet a owl:Class ;
    rdfs:subClassOf :CelestialBody ;
    rdfs:label "Dwarf Planet" .

:Moon a owl:Class ;
    rdfs:subClassOf :CelestialBody ;
    rdfs:label "Moon" .

:Ring a owl:Class ;
    rdfs:label "Ring" ;
    rdfs:comment "A ring system around a planet." .

:Spacecraft a owl:Class ;
    rdfs:label "Spacecraft" .

:SpaceMission a owl:Class ;
    rdfs:label "Space Mission" .

:SpaceAgency a owl:Class ;
    rdfs:label "Space Agency" .

# ---- Object Properties ----

:orbits a owl:ObjectProperty ;
    rdfs:label "orbits" ;
    rdfs:domain :CelestialBody ;
    rdfs:range :CelestialBody .

:hasRing a owl:ObjectProperty ;
    rdfs:label "has ring" ;
    rdfs:domain :Planet ;
    rdfs:range :Ring .

:hasMoon a owl:ObjectProperty ;
    rdfs:label "has moon" ;
    rdfs:domain :CelestialBody ;
    rdfs:range :Moon .

:visitedBy a owl:ObjectProperty ;
    rdfs:label "visited by" ;
    rdfs:domain :CelestialBody ;
    rdfs:range :Spacecraft .

:partOf a owl:ObjectProperty ;
    rdfs:label "part of" ;
    rdfs:domain :Spacecraft ;
    rdfs:range :SpaceMission .

:operatedBy a owl:ObjectProperty ;
    rdfs:label "operated by" ;
    rdfs:domain :SpaceMission ;
    rdfs:range :SpaceAgency .

:launchedFrom a owl:ObjectProperty ;
    rdfs:label "launched from" ;
    rdfs:domain :Spacecraft ;
    rdfs:range :CelestialBody .

# ---- Datatype Properties ----

:diameter a owl:DatatypeProperty ;
    rdfs:label "diameter" ;
    rdfs:domain :CelestialBody ;
    rdfs:range xsd:string .

:distanceFromSun a owl:DatatypeProperty ;
    rdfs:label "distance from Sun" ;
    rdfs:domain :CelestialBody ;
    rdfs:range xsd:string .

:orbitalPeriod a owl:DatatypeProperty ;
    rdfs:label "orbital period" ;
    rdfs:domain :CelestialBody ;
    rdfs:range xsd:string .

:discoveredYear a owl:DatatypeProperty ;
    rdfs:label "discovered" ;
    rdfs:domain :CelestialBody ;
    rdfs:range xsd:integer .

:launchDate a owl:DatatypeProperty ;
    rdfs:label "launch date" ;
    rdfs:domain :Spacecraft ;
    rdfs:range xsd:date .

:isActive a owl:DatatypeProperty ;
    rdfs:label "active" ;
    rdfs:domain :Spacecraft ;
    rdfs:range xsd:boolean .

:foundedYear a owl:DatatypeProperty ;
    rdfs:label "founded" ;
    rdfs:domain :SpaceAgency ;
    rdfs:range xsd:integer .

:headquarters a owl:DatatypeProperty ;
    rdfs:label "headquarters" ;
    rdfs:domain :SpaceAgency ;
    rdfs:range xsd:string .

:surfaceGravity a owl:DatatypeProperty ;
    rdfs:label "surface gravity" ;
    rdfs:domain :CelestialBody ;
    rdfs:range xsd:string .

:hasAtmosphere a owl:DatatypeProperty ;
    rdfs:label "has atmosphere" ;
    rdfs:domain :CelestialBody ;
    rdfs:range xsd:boolean .

# ============================================================
# Instances
# ============================================================

# ---- Star ----

:sun a :Star ;
    rdfs:label "Sun" ;
    :diameter "1,392,700 km" ;
    :surfaceGravity "274 m/s²" ;
    rdfs:comment "The star at the center of our solar system." .

# ---- Planets ----

:mercury a :Planet ;
    rdfs:label "Mercury" ;
    :orbits :sun ;
    :diameter "4,879 km" ;
    :distanceFromSun "57.9 million km" ;
    :orbitalPeriod "88 days" ;
    :surfaceGravity "3.7 m/s²" ;
    :hasAtmosphere false ;
    :visitedBy :messenger .

:venus a :Planet ;
    rdfs:label "Venus" ;
    :orbits :sun ;
    :diameter "12,104 km" ;
    :distanceFromSun "108.2 million km" ;
    :orbitalPeriod "225 days" ;
    :surfaceGravity "8.87 m/s²" ;
    :hasAtmosphere true ;
    :visitedBy :magellan .

:earth a :Planet ;
    rdfs:label "Earth" ;
    :orbits :sun ;
    :diameter "12,742 km" ;
    :distanceFromSun "149.6 million km" ;
    :orbitalPeriod "365.25 days" ;
    :surfaceGravity "9.81 m/s²" ;
    :hasAtmosphere true ;
    :hasMoon :luna .

:mars a :Planet ;
    rdfs:label "Mars" ;
    :orbits :sun ;
    :diameter "6,779 km" ;
    :distanceFromSun "227.9 million km" ;
    :orbitalPeriod "687 days" ;
    :surfaceGravity "3.72 m/s²" ;
    :hasAtmosphere true ;
    :hasMoon :phobos ;
    :hasMoon :deimos ;
    :visitedBy :curiosity ;
    :visitedBy :perseverance ;
    :visitedBy :ingenuity .

:jupiter a :Planet ;
    rdfs:label "Jupiter" ;
    :orbits :sun ;
    :diameter "139,820 km" ;
    :distanceFromSun "778.5 million km" ;
    :orbitalPeriod "11.86 years" ;
    :surfaceGravity "24.79 m/s²" ;
    :hasAtmosphere true ;
    :hasMoon :io ;
    :hasMoon :europa ;
    :hasMoon :ganymede ;
    :hasMoon :callisto ;
    :visitedBy :juno ;
    :visitedBy :voyager1 ;
    :visitedBy :voyager2 ;
    :hasRing :jupiter-ring .

:saturn a :Planet ;
    rdfs:label "Saturn" ;
    :orbits :sun ;
    :diameter "116,460 km" ;
    :distanceFromSun "1.434 billion km" ;
    :orbitalPeriod "29.46 years" ;
    :surfaceGravity "10.44 m/s²" ;
    :hasAtmosphere true ;
    :hasMoon :titan ;
    :hasMoon :enceladus ;
    :hasMoon :mimas ;
    :hasMoon :rhea ;
    :visitedBy :cassini ;
    :visitedBy :voyager1 ;
    :visitedBy :voyager2 ;
    :hasRing :saturn-ring .

:uranus a :Planet ;
    rdfs:label "Uranus" ;
    :orbits :sun ;
    :diameter "50,724 km" ;
    :distanceFromSun "2.871 billion km" ;
    :orbitalPeriod "84 years" ;
    :surfaceGravity "8.69 m/s²" ;
    :hasAtmosphere true ;
    :discoveredYear 1781 ;
    :hasMoon :titania ;
    :hasMoon :oberon ;
    :hasMoon :ariel ;
    :visitedBy :voyager2 ;
    :hasRing :uranus-ring .

:neptune a :Planet ;
    rdfs:label "Neptune" ;
    :orbits :sun ;
    :diameter "49,528 km" ;
    :distanceFromSun "4.495 billion km" ;
    :orbitalPeriod "164.8 years" ;
    :surfaceGravity "11.15 m/s²" ;
    :hasAtmosphere true ;
    :discoveredYear 1846 ;
    :hasMoon :triton ;
    :visitedBy :voyager2 ;
    :hasRing :neptune-ring .

# ---- Dwarf Planets ----

:pluto a :DwarfPlanet ;
    rdfs:label "Pluto" ;
    :orbits :sun ;
    :diameter "2,377 km" ;
    :distanceFromSun "5.906 billion km" ;
    :orbitalPeriod "248 years" ;
    :discoveredYear 1930 ;
    :hasMoon :charon ;
    :visitedBy :new-horizons .

:ceres a :DwarfPlanet ;
    rdfs:label "Ceres" ;
    :orbits :sun ;
    :diameter "939 km" ;
    :distanceFromSun "413.7 million km" ;
    :discoveredYear 1801 ;
    :visitedBy :dawn .

# ---- Moons ----

:luna a :Moon ;
    rdfs:label "Moon" ;
    :orbits :earth ;
    :diameter "3,474 km" ;
    :surfaceGravity "1.62 m/s²" ;
    :hasAtmosphere false ;
    :visitedBy :apollo-11 .

:phobos a :Moon ;
    rdfs:label "Phobos" ;
    :orbits :mars ;
    :diameter "22.4 km" .

:deimos a :Moon ;
    rdfs:label "Deimos" ;
    :orbits :mars ;
    :diameter "12.4 km" .

:io a :Moon ;
    rdfs:label "Io" ;
    :orbits :jupiter ;
    :diameter "3,643 km" ;
    :discoveredYear 1610 ;
    rdfs:comment "The most volcanically active body in the solar system." .

:europa a :Moon ;
    rdfs:label "Europa" ;
    :orbits :jupiter ;
    :diameter "3,122 km" ;
    :discoveredYear 1610 ;
    rdfs:comment "Subsurface ocean makes it a prime target for astrobiology." .

:ganymede a :Moon ;
    rdfs:label "Ganymede" ;
    :orbits :jupiter ;
    :diameter "5,268 km" ;
    :discoveredYear 1610 ;
    rdfs:comment "Largest moon in the solar system." .

:callisto a :Moon ;
    rdfs:label "Callisto" ;
    :orbits :jupiter ;
    :diameter "4,821 km" ;
    :discoveredYear 1610 .

:titan a :Moon ;
    rdfs:label "Titan" ;
    :orbits :saturn ;
    :diameter "5,149 km" ;
    :hasAtmosphere true ;
    :discoveredYear 1655 ;
    :visitedBy :huygens ;
    rdfs:comment "Only moon with a dense atmosphere. Has lakes of liquid methane." .

:enceladus a :Moon ;
    rdfs:label "Enceladus" ;
    :orbits :saturn ;
    :diameter "504 km" ;
    :discoveredYear 1789 ;
    rdfs:comment "Water-ice geysers erupt from its south pole." .

:mimas a :Moon ;
    rdfs:label "Mimas" ;
    :orbits :saturn ;
    :diameter "396 km" ;
    :discoveredYear 1789 .

:rhea a :Moon ;
    rdfs:label "Rhea" ;
    :orbits :saturn ;
    :diameter "1,527 km" ;
    :discoveredYear 1672 .

:titania a :Moon ;
    rdfs:label "Titania" ;
    :orbits :uranus ;
    :diameter "1,577 km" ;
    :discoveredYear 1787 .

:oberon a :Moon ;
    rdfs:label "Oberon" ;
    :orbits :uranus ;
    :diameter "1,523 km" ;
    :discoveredYear 1787 .

:ariel a :Moon ;
    rdfs:label "Ariel" ;
    :orbits :uranus ;
    :diameter "1,158 km" ;
    :discoveredYear 1851 .

:triton a :Moon ;
    rdfs:label "Triton" ;
    :orbits :neptune ;
    :diameter "2,707 km" ;
    :discoveredYear 1846 ;
    :hasAtmosphere true ;
    rdfs:comment "Only large moon with a retrograde orbit. Likely a captured Kuiper Belt object." .

:charon a :Moon ;
    rdfs:label "Charon" ;
    :orbits :pluto ;
    :diameter "1,212 km" ;
    :discoveredYear 1978 .

# ---- Rings ----

:jupiter-ring a :Ring ;
    rdfs:label "Jupiter Ring System" ;
    rdfs:comment "Faint ring system discovered by Voyager 1 in 1979." .

:saturn-ring a :Ring ;
    rdfs:label "Saturn Ring System" ;
    rdfs:comment "The most extensive and visible ring system in the solar system." .

:uranus-ring a :Ring ;
    rdfs:label "Uranus Ring System" ;
    :discoveredYear 1977 .

:neptune-ring a :Ring ;
    rdfs:label "Neptune Ring System" ;
    :discoveredYear 1984 .

# ---- Space Agencies ----

:nasa a :SpaceAgency ;
    rdfs:label "NASA" ;
    :foundedYear 1958 ;
    :headquarters "Washington, D.C." ;
    rdfs:comment "National Aeronautics and Space Administration." .

:esa a :SpaceAgency ;
    rdfs:label "ESA" ;
    :foundedYear 1975 ;
    :headquarters "Paris, France" ;
    rdfs:comment "European Space Agency." .

:jaxa a :SpaceAgency ;
    rdfs:label "JAXA" ;
    :foundedYear 2003 ;
    :headquarters "Tokyo, Japan" .

# ---- Space Missions ----

:voyager-program a :SpaceMission ;
    rdfs:label "Voyager Program" ;
    :operatedBy :nasa ;
    rdfs:comment "Twin spacecraft launched in 1977 to study the outer planets." .

:cassini-huygens a :SpaceMission ;
    rdfs:label "Cassini-Huygens" ;
    :operatedBy :nasa ;
    rdfs:comment "Joint NASA/ESA mission to Saturn, 1997-2017." .

:mars-2020 a :SpaceMission ;
    rdfs:label "Mars 2020" ;
    :operatedBy :nasa .

:juno-mission a :SpaceMission ;
    rdfs:label "Juno Mission" ;
    :operatedBy :nasa .

:new-horizons-mission a :SpaceMission ;
    rdfs:label "New Horizons Mission" ;
    :operatedBy :nasa .

:apollo-program a :SpaceMission ;
    rdfs:label "Apollo Program" ;
    :operatedBy :nasa ;
    rdfs:comment "Human spaceflight program that landed the first humans on the Moon." .

:dawn-mission a :SpaceMission ;
    rdfs:label "Dawn Mission" ;
    :operatedBy :nasa .

# ---- Spacecraft ----

:voyager1 a :Spacecraft ;
    rdfs:label "Voyager 1" ;
    :launchDate "1977-09-05"^^xsd:date ;
    :isActive true ;
    :partOf :voyager-program ;
    :launchedFrom :earth ;
    rdfs:comment "Farthest human-made object from Earth. Now in interstellar space." .

:voyager2 a :Spacecraft ;
    rdfs:label "Voyager 2" ;
    :launchDate "1977-08-20"^^xsd:date ;
    :isActive true ;
    :partOf :voyager-program ;
    :launchedFrom :earth ;
    rdfs:comment "Only spacecraft to have visited all four giant planets." .

:cassini a :Spacecraft ;
    rdfs:label "Cassini" ;
    :launchDate "1997-10-15"^^xsd:date ;
    :isActive false ;
    :partOf :cassini-huygens ;
    :launchedFrom :earth ;
    rdfs:comment "Orbited Saturn for 13 years. Destroyed by intentional atmospheric entry in 2017." .

:huygens a :Spacecraft ;
    rdfs:label "Huygens" ;
    :launchDate "1997-10-15"^^xsd:date ;
    :isActive false ;
    :partOf :cassini-huygens ;
    rdfs:comment "ESA probe that landed on Titan — the farthest landing from Earth." .

:curiosity a :Spacecraft ;
    rdfs:label "Curiosity" ;
    :launchDate "2011-11-26"^^xsd:date ;
    :isActive true ;
    :partOf :mars-2020 ;
    :launchedFrom :earth ;
    rdfs:comment "Mars rover exploring Gale Crater since 2012." .

:perseverance a :Spacecraft ;
    rdfs:label "Perseverance" ;
    :launchDate "2020-07-30"^^xsd:date ;
    :isActive true ;
    :partOf :mars-2020 ;
    :launchedFrom :earth ;
    rdfs:comment "Mars rover searching for signs of ancient microbial life in Jezero Crater." .

:ingenuity a :Spacecraft ;
    rdfs:label "Ingenuity" ;
    :launchDate "2020-07-30"^^xsd:date ;
    :isActive false ;
    :partOf :mars-2020 ;
    rdfs:comment "First powered flight on another planet. Retired April 2024." .

:juno a :Spacecraft ;
    rdfs:label "Juno" ;
    :launchDate "2011-08-05"^^xsd:date ;
    :isActive true ;
    :partOf :juno-mission ;
    :launchedFrom :earth ;
    rdfs:comment "Studying Jupiter's atmosphere, magnetosphere, and interior." .

:new-horizons a :Spacecraft ;
    rdfs:label "New Horizons" ;
    :launchDate "2006-01-19"^^xsd:date ;
    :isActive true ;
    :partOf :new-horizons-mission ;
    :launchedFrom :earth ;
    rdfs:comment "First spacecraft to fly by Pluto (2015) and Kuiper Belt object Arrokoth (2019)." .

:messenger a :Spacecraft ;
    rdfs:label "MESSENGER" ;
    :launchDate "2004-08-03"^^xsd:date ;
    :isActive false ;
    :launchedFrom :earth ;
    rdfs:comment "First spacecraft to orbit Mercury. Mission ended 2015." .

:magellan a :Spacecraft ;
    rdfs:label "Magellan" ;
    :launchDate "1989-05-04"^^xsd:date ;
    :isActive false ;
    :launchedFrom :earth ;
    rdfs:comment "Mapped 98% of Venus's surface using radar." .

:apollo-11 a :Spacecraft ;
    rdfs:label "Apollo 11" ;
    :launchDate "1969-07-16"^^xsd:date ;
    :isActive false ;
    :partOf :apollo-program ;
    :launchedFrom :earth ;
    rdfs:comment "First crewed mission to land on the Moon. Neil Armstrong and Buzz Aldrin walked on the lunar surface." .

:dawn a :Spacecraft ;
    rdfs:label "Dawn" ;
    :launchDate "2007-09-27"^^xsd:date ;
    :isActive false ;
    :partOf :dawn-mission ;
    :launchedFrom :earth ;
    rdfs:comment "First spacecraft to orbit two extraterrestrial bodies (Vesta and Ceres)." .
